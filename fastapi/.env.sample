# AWS Bedrock（Claude）
BEDROCK_AWS_ACCESS_KEY_ID=
BEDROCK_AWS_SECRET_ACCESS_KEY=
BEDROCK_AWS_REGION=us-east-1
# 省略時は Claude Haiku 4.5 を使用
BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0

# Yahoo Shopping API
YAHOO_APP_ID=
YAHOO_AFFILIATE_ID=
VC_SID=
VC_PID=

# Rakuten API（2026年以降: openapi.rakuten.co.jp + accessKey 必須）
# 公式: https://webservice.rakuten.co.jp/documentation/ichiba-item-search
RAKUTEN_APP_ID=
RAKUTEN_ACCESS_KEY=
RAKUTEN_AFFILIATE_ID=
# 楽天アプリ登録の許可ドメインと一致させる（例: https://shoppie-agent.com/）
RAKUTEN_HTTP_REFERER=https://shoppie-agent.com/

# Amazon Creators API（推奨・PA-API後継）
# 日本: https://affiliate.amazon.co.jp/creatorsapi で Credential ID / Secret を発行
# 要: 過去30日間に適格な発送済み売上10件以上（PA-APIと同条件・デバイス/ギフトカード等は対象外）
# 日本は v3.3 推奨（トークン: api.amazon.co.jp/auth/o2/token）
AMAZON_CREATORS_CREDENTIAL_ID=
AMAZON_CREATORS_CREDENTIAL_SECRET=
AMAZON_CREATORS_VERSION=3.3
AMAZON_PARTNER_TAG=
AMAZON_MARKETPLACE=www.amazon.co.jp

# Amazon PA-API 5.0（廃止予定・後方互換。Creators API を優先）
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_REGION=us-west-2

# 会話文脈は LangGraph MemorySaver（プロセス内メモリ）で保持。永続化はしない。
# 最終アクセスから3分間操作がない thread_id は自動削除される。
