  "components": {
    "schemas": {
      "AgentResponseSchema": {
        "properties": {
          "message": {
            "type": "string",
            "title": "Message"
          },
          "products": {
            "items": {
              "$ref": "#/components/schemas/ProductSchema"
            },
            "type": "array",
            "title": "Products"
          }
        },
        "type": "object",
        "required": [
          "message",
          "products"
        ],
        "title": "AgentResponseSchema"
      },
      "DeleteAllSessionsResponse": {
        "properties": {
          "deleted_sessions": {
            "type": "integer",
            "title": "Deleted Sessions"
          },
          "deleted_memories": {
            "type": "integer",
            "title": "Deleted Memories"
          }
        },
        "type": "object",
        "required": [
          "deleted_sessions",
          "deleted_memories"
        ],
        "title": "DeleteAllSessionsResponse"
      },
      "DeleteSessionResponse": {
        "properties": {
          "thread_id": {
            "type": "string",
            "title": "Thread Id"
          },
          "deleted_session": {
            "type": "boolean",
            "title": "Deleted Session"
          },
          "deleted_memory": {
            "type": "boolean",
            "title": "Deleted Memory"
          }
        },
        "type": "object",
        "required": [
          "thread_id",
          "deleted_session",
          "deleted_memory"
        ],
        "title": "DeleteSessionResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "MemoryMessageSchema": {
        "properties": {
          "role": {
            "type": "string",
            "title": "Role"
          },
          "content": {
            "type": "string",
            "title": "Content"
          }
        },
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "title": "MemoryMessageSchema"
      },
      "ProductPreviewSchema": {
        "properties": {
          "title": {
            "type": "string",
            "title": "Title"
          },
          "price": {
            "type": "string",
            "title": "Price"
          }
        },
        "type": "object",
        "required": [
          "title",
          "price"
        ],
        "title": "ProductPreviewSchema"
      },
      "ProductSchema": {
        "properties": {
          "title": {
            "type": "string",
            "title": "Title"
          },
          "price": {
            "type": "integer",
            "title": "Price"
          },
          "image_urls": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Image Urls"
          },
          "affiliate_url": {
            "type": "string",
            "title": "Affiliate Url"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          }
        },
        "type": "object",
        "required": [
          "title",
          "price",
          "image_urls",
          "affiliate_url"
        ],
        "title": "ProductSchema"
      },
      "RequestAssistanceBody": {
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1,
            "title": "Text"
          },
          "context_id": {
            "type": "string",
            "minLength": 1,
            "title": "Context Id"
          }
        },
        "type": "object",
        "required": [
          "text",
          "context_id"
        ],
        "title": "RequestAssistanceBody"
      },
      "RequestAssistanceResponse": {
        "properties": {
          "response": {
            "$ref": "#/components/schemas/AgentResponseSchema"
          }
        },
        "type": "object",
        "required": [
          "response"
        ],
        "title": "RequestAssistanceResponse"
      },
      "SessionDetailSchema": {
        "properties": {
          "thread_id": {
            "type": "string",
            "title": "Thread Id"
          },
          "created_at": {
            "type": "string",
            "title": "Created At"
          },
          "last_active_at": {
            "type": "string",
            "title": "Last Active At"
          },
          "turn_count": {
            "type": "integer",
            "title": "Turn Count"
          },
          "last_user_message": {
            "type": "string",
            "title": "Last User Message"
          },
          "memory_only": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
