            "title": "Memory Only"
          },
          "turns": {
            "items": {
              "$ref": "#/components/schemas/SessionTurnSchema"
            },
            "type": "array",
            "title": "Turns"
          },
          "memory_messages": {
            "items": {
              "$ref": "#/components/schemas/MemoryMessageSchema"
            },
            "type": "array",
            "title": "Memory Messages"
          }
        },
        "type": "object",
        "required": [
          "thread_id",
          "created_at",
          "last_active_at",
          "turn_count",
          "last_user_message"
        ],
        "title": "SessionDetailSchema"
      },
      "SessionListResponse": {
        "properties": {
          "sessions": {
            "items": {
              "$ref": "#/components/schemas/SessionSummarySchema"
            },
            "type": "array",
            "title": "Sessions"
          }
        },
        "type": "object",
        "required": [
          "sessions"
        ],
        "title": "SessionListResponse"
      },
      "SessionSummarySchema": {
        "properties": {
          "thread_id": {
            "type": "string",
            "title": "Thread Id"
          },
          "created_at": {
            "type": "string",
            "title": "Created At"
          },
          "last_active_at": {
            "type": "string",
            "title": "Last Active At"
          },
          "turn_count": {
            "type": "integer",
            "title": "Turn Count"
          },
          "last_user_message": {
            "type": "string",
            "title": "Last User Message"
          },
          "memory_only": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Memory Only"
          }
        },
        "type": "object",
        "required": [
          "thread_id",
          "created_at",
          "last_active_at",
          "turn_count",
          "last_user_message"
        ],
        "title": "SessionSummarySchema"
      },
      "SessionTurnSchema": {
        "properties": {
          "timestamp": {
            "type": "string",
            "title": "Timestamp"
          },
          "user_message": {
            "type": "string",
            "title": "User Message"
          },
          "assistant_message": {
            "type": "string",
            "title": "Assistant Message"
          },
          "product_count": {
            "type": "integer",
            "title": "Product Count"
          },
          "products_preview": {
            "items": {
              "$ref": "#/components/schemas/ProductPreviewSchema"
            },
            "type": "array",
            "title": "Products Preview"
