{
  "openapi": "3.1.0",
  "info": {
    "title": "FastAPI",
    "version": "0.1.0"
  },
  "paths": {
    "/chat": {
      "post": {
        "summary": "Chat",
        "operationId": "chat_chat_post",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/request-assistance": {
      "post": {
        "summary": "Request Assistance",
        "operationId": "request_assistance_request_assistance_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RequestAssistanceBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestAssistanceResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/context/{context_id}": {
      "delete": {
        "summary": "Delete Context",
        "operationId": "delete_context_context__context_id__delete",
        "parameters": [
          {
            "name": "context_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Context Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteContextResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AgentResponseSchema": {
        "properties": {
          "message": {
            "type": "string",
            "title": "Message"
          },
          "products": {
            "items": {
              "$ref": "#/components/schemas/ProductSchema"
            },
            "type": "array",
            "title": "Products"
          }
        },
        "type": "object",
        "required": [
          "message",
          "products"
        ],
        "title": "AgentResponseSchema"
      },
      "DeleteContextResponse": {
        "properties": {
          "context_id": {
            "type": "string",
            "title": "Context Id"
          },
          "deleted": {
            "type": "boolean",
            "title": "Deleted"
          }
        },
        "type": "object",
        "required": [
          "context_id",
          "deleted"
        ],
        "title": "DeleteContextResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ProductSchema": {
        "properties": {
          "title": {
            "type": "string",
            "title": "Title"
          },
          "price": {
            "type": "integer",
            "title": "Price"
          },
          "image_urls": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Image Urls"
          },
          "affiliate_url": {
            "type": "string",
            "title": "Affiliate Url"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "marketplace": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Marketplace"
          }
        },
        "type": "object",
        "required": [
          "title",
          "price",
          "image_urls",
          "affiliate_url"
        ],
        "title": "ProductSchema"
      },
      "RequestAssistanceBody": {
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1,
            "title": "Text"
          },
          "context_id": {
            "type": "string",
            "minLength": 1,
            "title": "Context Id"
          }
        },
        "type": "object",
        "required": [
          "text",
          "context_id"
        ],
        "title": "RequestAssistanceBody"
      },
      "RequestAssistanceResponse": {
        "properties": {
          "response": {
            "$ref": "#/components/schemas/AgentResponseSchema"
          }
        },
        "type": "object",
        "required": [
          "response"
        ],
        "title": "RequestAssistanceResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
