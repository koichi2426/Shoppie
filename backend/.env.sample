# AWS Bedrock（Claude）
BEDROCK_AWS_ACCESS_KEY_ID=
BEDROCK_AWS_SECRET_ACCESS_KEY=
BEDROCK_AWS_REGION=us-east-1
# 省略時は Claude Haiku 4.5 を使用
BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0

# Yahoo Shopping API（現在有効な商品検索ツール）
YAHOO_APP_ID=
YAHOO_AFFILIATE_ID=
VC_SID=
VC_PID=

# Rakuten API（ツール有効化時に必要）
RAKUTEN_APP_ID=
RAKUTEN_AFFILIATE_ID=

# Amazon Product Advertising API（ツール有効化時に必要）
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=
AMAZON_REGION=

# 管理画面 API キー（フロントの ADMIN_API_KEY と同じ値）
ADMIN_API_KEY=
